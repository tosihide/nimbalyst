{
  "id": "com.nimbalyst.github-issues-importer",
  "name": "GitHub Issues Importer",
  "version": "1.0.0",
  "description": "Import GitHub issues into the Nimbalyst tracker as native items that link back to their source. Uses your installed GitHub CLI (gh) for auth and access.",
  "author": "Nimbalyst",
  "main": "dist/index.js",
  "apiVersion": "1.0.0",
  "defaultEnabled": true,
  "permissions": {
    "network": true
  },
  "contributions": {
    "trackerImporters": [
      {
        "id": "github-issues",
        "displayName": "GitHub Issues",
        "icon": "bug_report",
        "urnScheme": "github",
        "backendModuleId": "github-issues-backend",
        "importsAs": ["bug", "task", "feature"]
      }
    ],
    "backendModules": [
      {
        "id": "github-issues-backend",
        "entry": "dist/backend.js",
        "runtime": "utility-process",
        "permissions": [],
        "enablement": {
          "default": "disabled",
          "promptOn": "firstUse",
          "purpose": "Read GitHub issues via your installed GitHub CLI (gh) so you can import them into the tracker."
        }
      }
    ]
  },
  "marketplace": {
    "categories": ["developer-tools", "integration"],
    "tags": ["github", "issues", "tracker", "import"],
    "icon": "bug_report",
    "tagline": "Import GitHub issues into your tracker",
    "fileTypes": []
  }
}
