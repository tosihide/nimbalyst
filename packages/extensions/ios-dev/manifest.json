{
  "id": "com.nimbalyst.ios-dev",
  "name": "iOS Development Tools",
  "version": "0.1.1",
  "description": "Tools for iOS development including XcodeGen, simulator management, and deployment",
  "author": "Nimbalyst",
  "main": "dist/index.mjs",
  "apiVersion": "1.0.0",
  "requiredReleaseChannel": "alpha",
  "permissions": {
    "filesystem": true,
    "ai": true,
    "network": false
  },
  "contributions": {
    "aiTools": [
      "ios-dev.xcodegen",
      "ios-dev.simulator",
      "ios-dev.build",
      "ios-dev.app"
    ],
    "claudePlugin": {
      "path": "claude-plugin",
      "displayName": "iOS Dev Commands",
      "description": "Commands for iOS development workflows",
      "enabledByDefault": true,
      "commands": [
        {
          "name": "xcodegen",
          "description": "Generate and manage Xcode projects with XcodeGen"
        },
        {
          "name": "ios-simulator",
          "description": "Launch and manage iOS simulators"
        },
        {
          "name": "ios-build",
          "description": "Build and deploy iOS apps"
        },
        {
          "name": "fastlane",
          "description": "Automate iOS builds, code signing, and TestFlight deployments"
        }
      ]
    },
    "fileIcons": {
      "*.swift": "code",
      "*.xcodeproj": "folder",
      "*.xcworkspace": "folder",
      "*.storyboard": "widgets",
      "*.xib": "widgets",
      "*.xcassets": "image",
      "project.yml": "settings",
      "Fastfile": "settings",
      "Appfile": "settings",
      "Matchfile": "settings",
      "Gemfile": "settings"
    },
    "newFileMenu": [
      {
        "extension": ".swift",
        "displayName": "Swift File",
        "icon": "code",
        "defaultContent": "import UIKit\n\nclass MyClass {\n    \n}\n"
      }
    ]
  }
}
